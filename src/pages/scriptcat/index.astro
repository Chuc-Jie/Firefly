---
import { Icon } from "astro-icon/components";
import { getEntry, render } from "astro:content";
import Markdown from "@components/common/Markdown.astro";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

const scriptcatPost = await getEntry("spec", "scriptcat");

if (!scriptcatPost) {
	throw new Error("Scriptcat page content not found");
}

const { Content } = await render(scriptcatPost);
---

<MainGridLayout 
    title={scriptcatPost.data.title || "脚本猫脚本"} 
    description={scriptcatPost.data.description || "脚本猫脚本集合"}
>
    <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            <!-- 添加图标 + 标题区域（参考 gallery 的样式） -->
            <div class="mb-4">
                <div class="flex items-center gap-3 mb-3">
                    <div class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70">
                        <Icon name="material-symbols:code" class="text-[1.5rem]" />
                    </div>
                    <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
                        {scriptcatPost.data.title || "脚本猫脚本"}
                    </div>
                </div>
                {scriptcatPost.data.description && (
                    <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mb-4">
                        {scriptcatPost.data.description}
                    </p>
                )}
            </div>

            <!-- 正文内容 -->
            <Markdown class="mt-2">
                <Content />
            </Markdown>
        </div>
    </div>
</MainGridLayout>